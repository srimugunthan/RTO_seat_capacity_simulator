# Copy this file to .env and fill in your values.
# Only the provider you choose needs an API key.

# LLM provider: openai | anthropic | groq | ollama
LLM_PROVIDER=openai

# Model name for the chosen provider
# openai:    gpt-4o-mini | gpt-4o
# anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6
# groq:      llama-3.1-8b-instant | mixtral-8x7b-32768
# ollama:    llama3.1 | gemma2  (no API key needed, runs locally)
LLM_MODEL=gpt-4o-mini

# API keys — set only the one matching LLM_PROVIDER
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Default simulation backend: binomial | monte_carlo
DEFAULT_BACKEND=monte_carlo
